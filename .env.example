# ================================
# AI Avatar Kiosk - Configurazione
# ================================

# Anthropic Claude API Key
# Ottieni su: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs TTS API Key
# Ottieni su: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ID della voce ElevenLabs da usare per l'avatar
# Trovi le voci disponibili su: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI API Key (usata per Whisper STT)
# Ottieni su: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Porta del server (default: 3000)
PORT=3000

# Modello Claude da usare
CLAUDE_MODEL=claude-opus-4-6

# Personalità dell'avatar (system prompt)
AVATAR_NAME=Sofia
AVATAR_SYSTEM_PROMPT="Sei Sofia, un'assistente virtuale disponibile e professionale. Rispondi in modo chiaro, conciso e amichevole. Sei installata su un totem interattivo. Mantieni le risposte brevi (max 3 frasi) per una migliore esperienza utente."
