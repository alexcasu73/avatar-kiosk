# ================================
# AI Avatar Kiosk - Configurazione
# ================================

# ── Server ────────────────────────────────────────────────────────────────
# Porta su cui gira il server (default: 3000)
PORT=3000

# ── Admin ─────────────────────────────────────────────────────────────────
# Credenziali pannello di amministrazione
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ── Anthropic ─────────────────────────────────────────────────────────────
# API Key per Claude (AI provider)
# Ottieni su: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Modello Claude di default (può essere sovrascritto per ogni avatar)
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────
# API Key per OpenAI (usata per GPT e/o Whisper STT)
# Ottieni su: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs TTS ────────────────────────────────────────────────────────
# API Key per la sintesi vocale
# Ottieni su: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ID voce ElevenLabs di default
# Trovi le voci su: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
